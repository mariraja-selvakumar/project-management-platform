# Database Configuration
DATABASE_URL=mysql://root:secret@127.0.0.1:3306/platform

# Server Configuration
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Security Configuration
BCRYPT_ROUNDS=12
# Strong JWT secrets (minimum 64 characters)
JWT_SECRET=super_secret_jwt_access_token_key_that_is_at_least_64_characters_long_1234567890
JWT_REFRESH_SECRET=super_secret_jwt_refresh_token_key_that_is_at_least_64_characters_long_0987654321

# Frontend Configuration
VITE_API_BASE_URL=http://localhost:3000/api/v1
